# Copy to `.env` and fill in values for `docker compose up`.
# Compose auto-loads `.env` from this directory for variable substitution.

MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=fps
MYSQL_USER=fps
MYSQL_PASSWORD=change-me-app

# HS256 signing; use a long random value in real deployments (32+ chars recommended).
JWT_SECRET=change-me-jwt-secret-minimum-32-chars-recommended-for-hs256

# Comma-separated browser Origins allowed to call the APIs (CORS). Default includes the shooter page on :8090.
# CORS_ALLOWED_ORIGINS=http://localhost:8090,http://127.0.0.1:8090
