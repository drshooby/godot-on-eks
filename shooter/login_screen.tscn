[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://login_screen.gd" id="1_login"]

[node name="LoginScreen" type="CanvasLayer"]
layer = 10
script = ExtResource("1_login")

[node name="ColorRect" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.05, 0.05, 0.12, 0.92)

[node name="CenterContainer" type="CenterContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="CenterContainer"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="TitleLabel" type="Label" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 12
text = "Account"
horizontal_alignment = 1

[node name="EmailField" type="LineEdit" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 10
placeholder_text = "Email"

[node name="PasswordField" type="LineEdit" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 10
placeholder_text = "Password"

[node name="ErrorLabel" type="Label" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.45, 0.45, 1)
theme_override_font_sizes/font_size = 8
autowrap_mode = 3

[node name="LoginBtn" type="Button" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 10
text = "Login"

[node name="RegisterBtn" type="Button" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 10
text = "Register"

[node name="OfflineBtn" type="Button" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 9
text = "Continue offline"

[connection signal="pressed" from="CenterContainer/VBoxContainer/LoginBtn" to="." method="_on_login_pressed"]
[connection signal="pressed" from="CenterContainer/VBoxContainer/RegisterBtn" to="." method="_on_register_pressed"]
[connection signal="pressed" from="CenterContainer/VBoxContainer/OfflineBtn" to="." method="_on_offline_pressed"]
